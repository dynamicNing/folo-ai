ADMIN_PASSWORD_HASH=$2a$10$placeholder_replace_with_real_hash
JWT_SECRET=folo-ai-jwt-secret-change-me
PORT=3000

# 内容处理 pipeline（从 content-archive 拉 md 入库）
GITHUB_TOKEN=                 # GitHub PAT，避免 API 限流
GITHUB_WEBHOOK_SECRET=        # 线上 webhook 签名校验；本地留空即跳过
MINIMAX_API_KEY=              # 可选：内容 pipeline AI 补全 title/tags/summary

# 学习模块 AI 生成
LEARNING_AI_PROVIDER=minimax  # minimax | deepseek
LEARNING_AI_MODEL_PLAN=       # 可选：学习目录生成模型
LEARNING_AI_MODEL_CHAPTER=    # 可选：学习章节生成模型
MINIMAX_MODEL=MiniMax-Text-01 # provider=minimax 时的默认模型
MINIMAX_BASE_URL=             # 可选：provider=minimax 时覆盖接口地址
DEEPSEEK_API_KEY=             # provider=deepseek 时必填
DEEPSEEK_MODEL=deepseek-chat  # provider=deepseek 时的默认模型
DEEPSEEK_BASE_URL=            # 可选：provider=deepseek 时覆盖基础地址，如 https://api.deepseek.com

# 社交采集存档根目录（线上 /root/content-archive；本地建议指向 ./content-archive）
CONTENT_ARCHIVE_DIR=
# 社交采集脚本（仅线上使用，本地调试可留空）
COLLECTOR_SCRIPT=
