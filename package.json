{
  "name": "folo-ai",
  "version": "1.0.0",
  "description": "个人信息聚合站点 - folo-ai.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "start:legacy": "node server.js",
    "client:dev:legacy": "vite --config client/vite.config.js",
    "build:legacy": "vite build --config client/vite.config.js",
    "sync": "node scripts/sync.js",
    "db:reset": "node scripts/reset-db.js",
    "db:init": "node scripts/reset-db.js --yes && node scripts/sync.js",
    "archive:pull": "node scripts/pull-archive.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.0",
    "nuxt": "^3.14.0",
    "vue": "^3.5.32",
    "vue-router": "^4.5.0",
    "pinia": "^2.2.0",
    "@pinia/nuxt": "^0.5.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "^5.7.0",
    "vite": "^8.0.8",
    "vue-tsc": "^2.1.10"
  }
}
